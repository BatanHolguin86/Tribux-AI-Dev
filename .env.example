# Tribux AI — Environment Variables
# Copy this file to .env.local and fill in the values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-...

# Resend (transactional emails)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=alerts@yourdomain.com
ADMIN_ALERT_EMAIL=admin@yourdomain.com

# Sentry (error tracking)
NEXT_PUBLIC_SENTRY_DSN=https://...
SENTRY_AUTH_TOKEN=sntrys_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Plan & Trial configuration (optional — defaults shown)
# PLAN_TRIAL_DAYS=7
# PLAN_FREE_PHASE_01_FEATURES=1
# PLAN_FREE_AGENTS=cto_only

# Platform encryption key (32-byte hex, for encrypting stored tokens)
# PLATFORM_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Platform-level tokens (One-Click Setup — creates infra for user projects)
# PLATFORM_GITHUB_TOKEN=ghp_...           # GitHub PAT with repo + admin:org scopes
# PLATFORM_GITHUB_ORG=tribux-projects   # GitHub org name for created repos
# PLATFORM_SUPABASE_TOKEN=sbp_...         # Supabase Management API token (Account > Access Tokens)
# PLATFORM_SUPABASE_ORG_ID=org_...        # Supabase organization ID
# PLATFORM_VERCEL_TOKEN=...               # Vercel API token
# PLATFORM_VERCEL_TEAM_ID=team_...        # Vercel team/org ID

# Vercel (optional — for deploy automation in Phase 06/07)
# VERCEL_TOKEN=...
# VERCEL_TEAM_ID=team_...

# Stripe (optional — for billing integration)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_BUILDER=price_...
# STRIPE_PRICE_AGENCY=price_...

# E2E tests (optional — for authenticated flow)
# TEST_USER_EMAIL=test@example.com
# TEST_USER_PASSWORD=your-secure-password

# Dev: grant enterprise plan via script (requires SUPABASE_SERVICE_ROLE_KEY in .env.local)
# pnpm run plan:enterprise your@email.com
# Or SQL: scripts/sql/grant-enterprise-test-user.sql
